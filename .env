###> pegasus-test-tool ###
# Override with real values in .env.local (see .env.local.dist).
PEGASUS_API_BASE=
PEGASUS_API_USER=
PEGASUS_API_SECRET=
PEGASUS_CREATE_ORDER_PATH=/api/retailerOrder/createOrder
# Optional default SKU for the form; can be overridden in the UI per request.
PEGASUS_ITEM_SKU=
# Optional default EAN for the form; can be overridden in the UI per request.
PEGASUS_ITEM_EAN=
# Middleware staging DB (override in .env.local)
PEGASUS_STAGING_DB_IP=
PEGASUS_STAGING_DB_USER=
PEGASUS_STAGING_DB_PASSWORD=
PEGASUS_STAGING_DB_SCHEMA=
PEGASUS_STAGING_DB_PORT=3306
###< pegasus-test-tool ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
