# Copy to .env.local and adjust (file is gitignored).
# Pegasus Retailer API — create dummy orders.

PEGASUS_API_BASE=https://IHRE-INSTANZ
# Optional defaults; the web UI can send apiUser / apiSecret per request to override (e.g. wrong-password tests).
PEGASUS_API_USER=API_USER
PEGASUS_API_SECRET=API_SECRET
PEGASUS_CREATE_ORDER_PATH=/api/retailerorder/createOrder
# Optional: pre-fills the "Item-SKU" field; you can always override in the UI.
PEGASUS_ITEM_SKU=IHRE-INTERNE-SKU
