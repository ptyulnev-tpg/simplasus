{% set _route = app.request.attributes.get('_route') %}
<nav class="sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-brand-icon">⚡</div>
        <div class="sidebar-brand-text">Pegasus<br>Test Tools</div>
    </div>
    <div class="sidebar-section-label">Tools</div>
    <a href="{{ path('app_dummy_orders') }}" class="nav-item {{ _route == 'app_dummy_orders' ? 'active' : '' }}">
        <span class="nav-item-icon">📦</span>
        Test-Order Erstellung
    </a>
    <a href="{{ path('app_api_user') }}" class="nav-item {{ _route == 'app_api_user' ? 'active' : '' }}">
        <span class="nav-item-icon">👤</span>
        API User Erstellung
    </a>
    <a href="{{ path('app_cleanup') }}" class="nav-item {{ _route == 'app_cleanup' ? 'active' : '' }}">
        <span class="nav-item-icon">🧹</span>
        Duplicate B2B User Mails
    </a>
    <a href="{{ path('app_guidelines') }}" class="nav-item {{ _route starts with 'app_guidelines' ? 'active' : '' }}">
        <span class="nav-item-icon">📋</span>
        Guidelines
    </a>

    <div style="margin-top:auto;padding:1.5rem 1.1rem 0;border-top:1px solid var(--glass-border);">
        <div style="font-size:0.75rem;color:var(--subtle);margin-bottom:0.5rem;">{{ app.user.userIdentifier }}</div>
        <a href="{{ path('app_logout') }}" style="font-size:0.8rem;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:0.4rem;transition:color 0.15s;">
            <span>↩</span> Abmelden
        </a>
    </div>
</nav>
